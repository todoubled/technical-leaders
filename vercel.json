{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/ls",
      "destination": "https://drive.google.com/drive/u/1/folders/1s_UNK3dw7EJiToqHUl1uYWgioZJ9xfpH",
      "permanent": false
    },
    {
      "source": "/ai-agent-skills",
      "destination": "/join",
      "permanent": true
    },
    {
      "source": "/ai-workshop",
      "destination": "/join",
      "permanent": true
    },
    {
      "source": "/ai-workflows",
      "destination": "/join",
      "permanent": true
    },
    {
      "source": "/workshop",
      "destination": "/join",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/s2p-elevate-ai-guide",
      "destination": "/s2p-elevate-ai-guide.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
